root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Rego is tab-indented by `opa fmt`.
[*.rego]
indent_style = tab

# Makefiles require tab indentation.
[Makefile]
indent_style = tab

# Go uses tabs.
[*.go]
indent_style = tab

# Markdown preserves trailing spaces (used for hard line breaks).
[*.md]
trim_trailing_whitespace = false
